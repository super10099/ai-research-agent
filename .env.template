# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Cohere (reranking) ───────────────────────────────────────────────────────
COHERE_API_KEY=...

# ── LangSmith (tracing) ──────────────────────────────────────────────────────
# Create a project at smith.langchain.com, then paste the key here.
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=ai-research-agent
# Setting LANGCHAIN_TRACING_V2=true activates auto-instrumentation.
LANGCHAIN_TRACING_V2=true

# ── Tavily (web search) ──────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# false = in-process PersistentClient (local dev, no server needed)
# true  = HttpClient connecting to the chromadb Docker service
CHROMA_USE_HTTP=false
# Ignored when CHROMA_USE_HTTP=false.
# In docker-compose, docker-compose.yml overrides these to chromadb:8000.
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Application ──────────────────────────────────────────────────────────────
# Path where ChromaDB persists its on-disk index.
CHROMA_PERSIST_DIR=./data/chroma
# Path where SQLite checkpoints the LangGraph state.
LANGGRAPH_CHECKPOINT_DB=./data/checkpoints.db
# Embedding model — must match what was used when the index was built.
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Number of child chunks to retrieve before reranking.
RETRIEVAL_TOP_K=20
# Number of results to return after reranking.
RERANK_TOP_N=5
# FastAPI host/port.
API_HOST=0.0.0.0
API_PORT=8000
